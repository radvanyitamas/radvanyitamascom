---
interface Props {
  project: {
    id: number;
    title: string;
    description: string;
    category: string;
    tech_stack: string[];
    image_url: string;
    live_link?: string;
  };
  index: number;
}

const { project, index } = Astro.props;
---

<div
  class={`group relative flex flex-col overflow-hidden rounded-4xl bg-card border border-gray-800 transition-all duration-500 hover:-translate-y-2 hover:border-brand/50 hover:shadow-[0_15px_40px_-10px_rgba(0,255,204,0.15)] ${index === 0 ? "md:col-span-2 md:row-span-2" : ""}`}
>
  <div
    class={`relative overflow-hidden bg-gray-900 border-b border-gray-800 ${index === 0 ? "aspect-video md:aspect-auto md:h-full" : "aspect-video"}`}
  >
    <img
      src={project.image_url ||
        "https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=1000"}
      alt={project.title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-70 group-hover:opacity-100"
    />
    <div
      class="absolute top-4 right-4 bg-black/60 backdrop-blur-md border border-gray-700/50 text-white text-xs font-mono px-3 py-1.5 rounded-full uppercase tracking-wider z-10"
    >
      {project.category}
    </div>
  </div>

  <div
    class={`p-6 md:p-8 flex flex-col flex-1 ${index === 0 ? "md:absolute md:bottom-0 md:left-0 md:w-full md:bg-linear-to-t md:from-black md:via-black/90 md:to-transparent" : ""}`}
  >
    <h3
      class="text-2xl font-bold mb-3 group-hover:text-brand transition-colors"
    >
      {project.title}
    </h3>
    <p class="text-gray-400 text-sm mb-6 line-clamp-3">{project.description}</p>

    <div class="flex flex-wrap gap-2 mb-8">
      {
        project.tech_stack?.map((tech) => (
          <span class="text-xs font-medium bg-gray-800/80 text-gray-300 px-3 py-1.5 rounded-lg border border-gray-700/50 backdrop-blur-sm">
            {tech}
          </span>
        ))
      }
    </div>

    <div class="mt-auto flex items-center gap-6">
      <a
        href={`/projekt/${project.id}`}
        class="inline-flex items-center gap-2 text-sm font-bold text-white hover:text-brand transition-colors"
      >
        Részletek <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:translate-x-1 transition-transform"
          ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
        >
      </a>
      {
        project.live_link && (
          <a
            href={project.live_link}
            target="_blank"
            class="text-xs text-gray-500 hover:text-white transition-colors underline underline-offset-4"
          >
            Élő link
          </a>
        )
      }
    </div>
  </div>
</div>
