---

---

<section
  class="min-h-[80vh] flex flex-col justify-center mb-20 text-center md:text-left"
>
  <div
    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand/10 text-brand border border-brand/20 text-sm font-mono shadow-[0_0_15px_rgba(0,255,204,0.1)] w-fit mx-auto md:mx-0 mb-8"
  >
    <span class="relative flex h-2 w-2">
      <span
        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"
      ></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-brand"></span>
    </span>
    Elérhető új projektekre
  </div>

  <h1
    class="text-5xl md:text-8xl font-black tracking-tighter leading-[1.1] mb-6"
  >
    Kódba öntöm <br />
    <span
      class="text-transparent bg-clip-text bg-linear-to-r from-white via-gray-300 to-gray-600"
      >az ötleteidet.</span
    >
  </h1>

  <p class="text-gray-400 text-lg md:text-2xl max-w-3xl mb-12 leading-relaxed">
    Szabadúszó szoftverfejlesztőként modern, villámgyors weboldalakat, egyedi
    webes rendszereket és mobilalkalmazásokat tervezek.
  </p>

  <div class="flex flex-wrap gap-4 justify-center md:justify-start">
    <a
      href="#projects"
      class="px-8 py-4 bg-brand text-black font-bold rounded-full hover:shadow-[0_0_30px_rgba(0,255,204,0.4)] hover:-translate-y-1 transition-all duration-300"
    >
      Munkáim megtekintése
    </a>
  </div>
</section>
